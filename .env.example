GOOGLE_API_KEY=your_gemini_api_key_here

# AI servisleri açık mı? false ise placeholder cevap döner (geliştirme sırasında quota yakmamak için).
AI_ENABLED=false

# JWT imzalama anahtarı. Production için MUTLAKA güçlü rastgele değer üret (örn. `python -c "import secrets; print(secrets.token_hex(32))"`).
JWT_SECRET_KEY=replace-me-with-a-strong-random-secret
